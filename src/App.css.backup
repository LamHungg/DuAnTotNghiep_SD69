.App {
  text-align: center;
}

.App-logo {
  height: 40vmin;
  pointer-events: none;
}

@media (prefers-reduced-motion: no-preference) {
  .App-logo {
    animation: App-logo-spin infinite 20s linear;
  }
}

.App-header {
  background-color: #282c34;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: calc(10px + 2vmin);
  color: white;
}

.App-link {
  color: #61dafb;
}

@keyframes App-logo-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.active-menu {
  background: #f6f8fa !important;
  color: #2d3748 !important;
  font-weight: 600;
  box-shadow: 0 2px 8px 0 rgba(0, 0, 0, 0.03);
  border-radius: 8px;
}

.nav-link {
  transition: background 0.2s, color 0.2s;
}

.nav-link:hover {
  background: #f1f3f6;
  color: #2d3748 !important;
  border-radius: 8px;
}

.nav-link .me-2 {
  font-size: 18px;
  margin-right: 10px !important;
}

.nav {
  list-style: none;
  padding-left: 0;
}

.bg-white.border-end {
  border-right: 1px solid #e5e7eb !important;
}

.stat-card {
  background: white;
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 110px;
  border: 1px solid #f0f1f2;
  overflow: hidden;
}

.stat-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
  color: white;
  text-decoration: none;
}

.stat-title {
  font-size: 15px;
  color: #7b809a;
  font-weight: 500;
  margin-bottom: 8px;
}

.stat-change {
  font-size: 12px;
  font-weight: 500;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 2px solid #f8f9fa;
}

.badge {
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.loading-spinner {
  display: inline-block;
  padding: 6px 12px;
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: white;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border-radius: 50%;
  width: 35px;
  height: 35px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

@media (max-width: 768px) {
  .voucher-management,
  .voucher-management__header,
  .header-content h1 {
    font-size: 1.8rem;
  }

  .stats-grid {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
  }

  .stat-card {
    padding: 15px;
  }

  .search-filters {
    grid-template-columns: 1fr;
  }

  .voucher-grid,
  .promotion-grid {
    grid-template-columns: 1fr;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .form-actions {
    flex-direction: column;
  }

  .voucher-item__header,
  .promotion-item__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .voucher-item__actions,
  .promotion-item__actions {
    flex-direction: column;
  }
}

@media (max-width: 480px) {
  .voucher-management,
  .voucher-item,
  .promotion-item {
    padding: 15px;
  }

  .voucher-form-modal,
  .promotion-form-modal {
    width: 95%;
    margin: 10px;
  }

  .voucher-form,
  .promotion-form {
    padding: 15px;
  }

  .stats-grid {
    grid-template-columns: 1fr;
  }
}

/* Toast Container */
.toast-container {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 12px;
  pointer-events: none;
}

.toast-container > * {
  pointer-events: auto;
}

/* Toast Styles */
.toast {
  position: relative;
  min-width: 300px;
  max-width: 400px;
  background: white;
  border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  overflow: hidden;
  animation: slideInRight 0.3s ease-out;
  margin-bottom: 12px;
}

.toast-content {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  gap: 12px;
}

.toast-icon {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  animation: iconBounce 0.6s ease-out;
}

.toast-success .toast-icon {
  color: #10b981;
  background: rgba(16, 185, 129, 0.1);
}

.toast-error .toast-icon {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
}

.toast-warning .toast-icon {
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.1);
}

.toast-info .toast-icon {
  color: #3b82f6;
  background: rgba(59, 130, 246, 0.1);
}

.toast-message {
  flex: 1;
  font-size: 14px;
  font-weight: 500;
  color: #374151;
  line-height: 1.5;
}

.toast-close {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border: none;
  background: transparent;
  color: #9ca3af;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  transition: all 0.2s ease;
}

.toast-close:hover {
  background: rgba(156, 163, 175, 0.1);
  color: #6b7280;
}

.toast-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: rgba(0, 0, 0, 0.05);
}

.toast-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #8b5cf6);
  transition: width 0.1s linear;
}

.toast-success .toast-progress-bar {
  background: linear-gradient(90deg, #10b981, #059669);
}

.toast-error .toast-progress-bar {
  background: linear-gradient(90deg, #ef4444, #dc2626);
}

.toast-warning .toast-progress-bar {
  background: linear-gradient(90deg, #f59e0b, #d97706);
}

.toast-info .toast-progress-bar {
  background: linear-gradient(90deg, #3b82f6, #2563eb);
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes slideOutRight {
  from {
    transform: translateX(0);
    opacity: 1;
  }
  to {
    transform: translateX(100%);
    opacity: 0;
  }
}

@keyframes iconBounce {
  0%,
  20%,
  53%,
  80%,
  100% {
    transform: translate3d(0, 0, 0);
  }
  40%,
  43% {
    transform: translate3d(0, -8px, 0);
  }
  70% {
    transform: translate3d(0, -4px, 0);
  }
  90% {
    transform: translate3d(0, -2px, 0);
  }
}

@keyframes toast-progress {
  from {
    width: 100%;
  }
  to {
    width: 0%;
  }
}

/* Responsive design for toasts */
@media (max-width: 768px) {
  .toast {
    min-width: 280px;
    max-width: 320px;
  }

  .toast-content {
    padding: 14px 16px;
  }

  .toast-message {
    font-size: 13px;
  }
}

/* Dashboard Styles */
.dashboard-container {
  padding: 0;
}

.dashboard-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 2rem;
  border-radius: 16px;
  margin-bottom: 2rem;
  box-shadow: 0 8px 32px rgba(102, 126, 234, 0.15);
}

.dashboard-title {
  font-size: 2.5rem;
  font-weight: 700;
  margin: 0 0 0.5rem 0;
  display: flex;
  align-items: center;
}

.dashboard-subtitle {
  font-size: 1.1rem;
  opacity: 0.9;
  margin: 0;
}

/* Stat Cards */
.stat-card {
  background: white;
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.stat-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
}

.stat-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.stat-card-primary::before {
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.stat-card-warning::before {
  background: linear-gradient(90deg, #ffa726, #ff7043);
}

.stat-card-success::before {
  background: linear-gradient(90deg, #66bb6a, #43a047);
}

.stat-card-info::before {
  background: linear-gradient(90deg, #42a5f5, #1976d2);
}

.stat-card-icon {
  width: 60px;
  height: 60px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: white;
  margin-bottom: 1rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stat-card-warning .stat-card-icon {
  background: linear-gradient(135deg, #ffa726 0%, #ff7043 100%);
}

.stat-card-success .stat-card-icon {
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
}

.stat-card-info .stat-card-icon {
  background: linear-gradient(135deg, #42a5f5 0%, #1976d2 100%);
}

.stat-card-value {
  font-size: 2.5rem;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 0.5rem;
}

.stat-card-label {
  font-size: 1rem;
  color: #7f8c8d;
  font-weight: 500;
  margin-bottom: 0.5rem;
}

.stat-card-change {
  font-size: 0.85rem;
  font-weight: 500;
}

.stat-card-change.positive {
  color: #27ae60;
}

.stat-card-change.negative {
  color: #e74c3c;
}

/* Chart Cards */
.chart-card {
  background: white;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.chart-card-header {
  padding: 1.5rem;
  border-bottom: 1px solid #ecf0f1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chart-card-title {
  font-size: 1.25rem;
  font-weight: 600;
  color: #2c3e50;
  margin: 0;
}

.chart-card-body {
  padding: 1.5rem;
}

.chart-placeholder {
  height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  border-radius: 8px;
  border: 2px dashed #dee2e6;
}

.chart-placeholder-content {
  text-align: center;
  color: #6c757d;
}

.chart-placeholder-icon {
  font-size: 3rem;
  margin-bottom: 1rem;
  opacity: 0.5;
}

/* Order Distribution */
.order-distribution {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.distribution-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem;
  background: #f8f9fa;
  border-radius: 8px;
}

.distribution-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 500;
  color: #2c3e50;
}

.distribution-color {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}

.distribution-value {
  font-weight: 600;
  color: #2c3e50;
  font-size: 1.1rem;
}

/* Recent Orders */
.recent-orders-card {
  background: white;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  border: 1px solid rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.recent-orders-header {
  padding: 1.5rem;
  border-bottom: 1px solid #ecf0f1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recent-orders-title {
  font-size: 1.25rem;
  font-weight: 600;
  color: #2c3e50;
  margin: 0;
  display: flex;
  align-items: center;
}

.customer-info {
  display: flex;
  flex-direction: column;
}

.customer-name {
  font-weight: 500;
  color: #2c3e50;
}

.action-buttons {
  display: flex;
  gap: 0.25rem;
}

.action-buttons .btn {
  width: 32px;
  height: 32px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Table Improvements */
.table {
  margin: 0;
}

.table th {
  border-top: none;
  font-weight: 600;
  color: #2c3e50;
  padding: 1rem;
}

.table td {
  padding: 1rem;
  vertical-align: middle;
}

.table-hover tbody tr:hover {
  background-color: #f8f9fa;
}

/* Responsive */
@media (max-width: 768px) {
  .dashboard-header {
    padding: 1.5rem;
  }

  .dashboard-title {
    font-size: 2rem;
  }

  .stat-card {
    padding: 1rem;
  }

  .stat-card-value {
    font-size: 2rem;
  }

  .chart-card-header,
  .recent-orders-header {
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
}

/* Sidebar Improvements */
.sidebar-parent {
  transition: all 0.3s ease;
}

.sidebar-parent:hover {
  background: rgba(102, 126, 234, 0.1) !important;
  color: #667eea !important;
}

.sidebar-children {
  background: rgba(102, 126, 234, 0.05);
  border-radius: 8px;
  margin: 0.5rem 0;
  padding: 0.5rem 0;
}

.sidebar-child {
  transition: all 0.3s ease;
  margin: 0.25rem 0;
}

.sidebar-child:hover {
  background: rgba(102, 126, 234, 0.1) !important;
  color: #667eea !important;
}

.active-menu {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: white !important;
  box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
}

/* Clock Component */
.clock-container {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 12px;
  padding: 0.5rem 1rem;
  box-shadow: 0 4px 16px rgba(102, 126, 234, 0.2);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* Navigation Improvements */
.nav-link {
  transition: all 0.3s ease;
  border-radius: 8px;
  margin: 0.25rem 0;
}

.nav-link:hover {
  transform: translateX(4px);
}

/* Logout Button */
.logout-button {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border: none;
  color: white;
  padding: 0.75rem 1.5rem;
  border-radius: 8px;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4px 16px rgba(231, 76, 60, 0.3);
}

.logout-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(231, 76, 60, 0.4);
  background: linear-gradient(135deg, #c0392b 0%, #a93226 100%);
}

/* Dashboard Interactive Elements */
.stat-card-action {
  position: absolute;
  top: 1rem;
  right: 1rem;
  color: rgba(255, 255, 255, 0.7);
  font-size: 1.2rem;
  transition: all 0.3s ease;
  opacity: 0;
}

.stat-card:hover .stat-card-action {
  opacity: 1;
  color: white;
  transform: translateX(3px);
}

/* Dashboard Modal Styles - Specific for Dashboard */
.dashboard-modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1040;
}

.dashboard-modal {
  z-index: 1050;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.dashboard-modal-dialog {
  margin: 0 auto;
  max-width: 800px;
  width: 100%;
  transform: none !important;
  position: relative;
}

.dashboard-modal-content {
  border: none;
  border-radius: 16px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  max-height: 90vh;
  overflow-y: auto;
  margin: 0 auto;
  position: relative;
  background: white;
}

.dashboard-modal-header {
  border-bottom: 1px solid #e9ecef;
  padding: 1.5rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 16px 16px 0 0;
  position: sticky;
  top: 0;
  z-index: 1;
}

.dashboard-modal-title {
  font-weight: 600;
  margin: 0;
}

.dashboard-modal-body {
  padding: 1.5rem;
}

.dashboard-modal-footer {
  border-top: 1px solid #e9ecef;
  padding: 1rem 1.5rem;
  background: #f8f9fa;
  border-radius: 0 0 16px 16px;
  position: sticky;
  bottom: 0;
  z-index: 1;
}

/* Modal Content Styles */
.info-section {
  background: #f8f9fa;
  border-radius: 12px;
  padding: 1.5rem;
  margin-bottom: 1rem;
  border: 1px solid #e9ecef;
}

.info-section-title {
  color: #2c3e50;
  font-weight: 600;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  font-size: 1.1rem;
}

.info-section-title svg {
  color: #667eea;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 0;
  border-bottom: 1px solid #e9ecef;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-weight: 500;
  color: #6c757d;
  min-width: 120px;
}

.info-value {
  font-weight: 600;
  color: #2c3e50;
  text-align: right;
}

.info-value.order-id {
  color: #667eea;
  font-family: "Courier New", monospace;
  font-weight: 700;
}

.payment-info {
  background: white;
  border-radius: 8px;
  padding: 1rem;
  border: 1px solid #e9ecef;
}

.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0;
  border-bottom: 1px solid #f8f9fa;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-item.total {
  border-top: 2px solid #667eea;
  margin-top: 0.5rem;
  padding-top: 1rem;
}

.payment-label {
  font-weight: 500;
  color: #6c757d;
}

.payment-value {
  font-weight: 600;
  color: #2c3e50;
}

.payment-value.total-amount {
  color: #667eea;
  font-size: 1.1rem;
  font-weight: 700;
}

.products-placeholder {
  background: #f8f9fa;
  border-radius: 8px;
  padding: 1.5rem;
  text-align: center;
  border: 2px dashed #dee2e6;
}

.products-placeholder p {
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.products-placeholder svg {
  color: #6c757d;
}

.modal-header {
  border-bottom: 1px solid #e9ecef;
  padding: 1.5rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 16px 16px 0 0;
  position: sticky;
  top: 0;
  z-index: 1;
}

.modal-title {
  font-weight: 600;
  margin: 0;
}

.modal-body {
  padding: 1.5rem;
}

.modal-footer {
  border-top: 1px solid #e9ecef;
  padding: 1rem 1.5rem;
  background: #f8f9fa;
  border-radius: 0 0 16px 16px;
  position: sticky;
  bottom: 0;
  z-index: 1;
}

/* Modal responsive */
@media (max-width: 768px) {
  .modal {
    padding: 0.5rem !important;
    align-items: flex-start !important;
    padding-top: 2rem !important;
  }

  .modal-dialog {
    max-width: 95% !important;
    margin: 0 auto !important;
  }

  .modal-content {
    max-height: 90vh !important;
    border-radius: 12px !important;
  }

  .modal-header,
  .modal-body,
  .modal-footer {
    padding: 1rem !important;
  }

  .modal-title {
    font-size: 1.1rem !important;
  }
}

@media (max-width: 576px) {
  .modal {
    padding: 0.25rem !important;
    padding-top: 1rem !important;
  }

  .modal-dialog {
    max-width: 98% !important;
  }

  .modal-content {
    max-height: 85vh !important;
  }
}

/* Override Bootstrap modal styles */
.modal.fade.show {
  display: flex !important;
  opacity: 1 !important;
  visibility: visible !important;
}

/* Ensure modal is always on top */
.modal.show {
  z-index: 1050 !important;
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  width: 100% !important;
  height: 100% !important;
  background-color: rgba(0, 0, 0, 0.5) !important;
}

.modal-dialog.modal-lg {
  max-width: 800px !important;
  margin: 0 auto !important;
  transform: none !important;
}

.modal-content {
  border: none !important;
  border-radius: 16px !important;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2) !important;
  margin: 0 auto !important;
}

/* Force modal centering */
.modal {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 1rem !important;
  z-index: 1050 !important;
}

.modal-dialog {
  margin: 0 auto !important;
  transform: none !important;
  position: relative !important;
  max-width: 800px !important;
}

/* Fix modal backdrop */
.modal-backdrop {
  z-index: 1040 !important;
}

/* Ensure modal content is properly styled */
.modal-content {
  border: none !important;
  border-radius: 16px !important;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2) !important;
  overflow: hidden !important;
}

/* Fix modal header */
.modal-header {
  border-bottom: 1px solid #e9ecef !important;
  padding: 1rem 1.5rem !important;
  background: #fff !important;
}

/* Fix modal body */
.modal-body {
  padding: 1.5rem !important;
  max-height: 70vh !important;
  overflow-y: auto !important;
}

/* Fix modal footer */
.modal-footer {
  border-top: 1px solid #e9ecef !important;
  padding: 1rem 1.5rem !important;
  background: #f8f9fa !important;
  border-radius: 0 0 16px 16px !important;
}

/* Refresh Button Animation */
.fa-spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* Dashboard Header Refresh Button */
.dashboard-header .btn-outline-primary {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: white;
  transition: all 0.3s ease;
}

.dashboard-header .btn-outline-primary:hover {
  background: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 255, 255, 0.5);
  color: white;
  transform: translateY(-1px);
}

.dashboard-header .btn-outline-primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

/* =====================================
   ADDITIONAL STYLES FROM MAIN.CSS
   ===================================== */

/* Promotion Management Styles */

.search-filters {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 15px;
  align-items: end;
}

.search-filters input,
.search-filters select {
  padding: 12px 16px;
  border: 2px solid #e9ecef;
  border-radius: 10px;
  font-size: 0.95rem;
  transition: all 0.3s ease;
  background: #f8f9fa;
}

.search-filters input:focus,
.search-filters select:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  background: white;
}

.promotion-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 20px;
}

.promotion-item {
  background: white;
  border-radius: 15px;
  padding: 20px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border: 1px solid #e9ecef;
  position: relative;
  overflow: hidden;
}

.promotion-item::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.promotion-item:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
}

.promotion-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
  padding-bottom: 15px;
  border-bottom: 1px solid #e9ecef;
}

.promotion-item__code {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  color: #667eea;
  font-size: 0.9rem;
}

.promotion-item__code svg {
  color: #764ba2;
}

.promotion-item__status {
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.promotion-item__content {
  margin-bottom: 20px;
}

.promotion-item__title {
  margin: 0 0 15px 0;
  font-size: 1.2rem;
  font-weight: 700;
  color: #2c3e50;
  line-height: 1.3;
}

.promotion-item__discount {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 15px;
  padding: 12px;
  background: linear-gradient(135deg, #f8f9ff, #e3f2fd);
  border-radius: 10px;
  border-left: 4px solid #667eea;
}

.discount-label {
  font-weight: 600;
  color: #495057;
}

.discount-value {
  display: flex;
  align-items: center;
  gap: 5px;
  font-weight: 700;
  color: #667eea;
  font-size: 1.1rem;
}

.discount-value svg {
  color: #764ba2;
}

.promotion-item__dates {
  margin-bottom: 15px;
}

.date-item {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  font-size: 0.9rem;
  color: #6c757d;
}

.date-item svg {
  color: #667eea;
  font-size: 0.8rem;
}

.promotion-item__remaining {
  margin-bottom: 15px;
}

.remaining-text {
  display: inline-block;
  padding: 6px 12px;
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: white;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.promotion-item__description {
  margin: 0;
  font-size: 0.9rem;
  color: #6c757d;
  line-height: 1.5;
  font-style: italic;
}

.promotion-item__actions {
  display: flex;
  gap: 10px;
  padding-top: 15px;
  border-top: 1px solid #e9ecef;
}

.btn-edit,
.btn-delete {
  flex: 1;
  padding: 10px 16px;
  border: none;
  border-radius: 8px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.btn-edit {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

.btn-edit:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.btn-delete {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: white;
}

.btn-delete:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(255, 107, 107, 0.4);
}

/* Promotion Form Modal */
.promotion-form-modal {
  background: white;
  border-radius: 15px;
  max-width: 600px;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.promotion-form-modal__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 15px 15px 0 0;
}

.promotion-form-modal__header h2 {
  margin: 0;
  font-size: 1.5rem;
  font-weight: 700;
}

.modal-close {
  background: none;
  border: none;
  color: white;
  font-size: 1.5rem;
  cursor: pointer;
  padding: 5px;
  border-radius: 50%;
  width: 35px;
  height: 35px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.modal-close:hover {
  background: rgba(255, 255, 255, 0.2);
}

.promotion-form {
  padding: 20px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 20px;
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-group label {
  margin-bottom: 8px;
  font-weight: 600;
  color: #495057;
  font-size: 0.95rem;
}

.form-group input,
.form-group select,
.form-group textarea {
  padding: 12px 16px;
  border: 2px solid #e9ecef;
  border-radius: 8px;
  font-size: 0.95rem;
  transition: all 0.3s ease;
  background: #f8f9fa;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  background: white;
}

.input-with-icon {
  position: relative;
}

.input-with-icon input {
  padding-right: 40px;
}

.input-icon {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #667eea;
  font-size: 1rem;
}

.form-actions {
  display: flex;
  gap: 15px;
  justify-content: flex-end;
  margin-top: 30px;
  padding-top: 20px;
  border-top: 1px solid #e9ecef;
}

/* Responsive Design */
@media (max-width: 768px) {
  .search-filters {
    grid-template-columns: 1fr;
  }

  .promotion-grid {
    grid-template-columns: 1fr;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .form-actions {
    flex-direction: column;
  }

  .promotion-item__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .promotion-item__actions {
    flex-direction: column;
  }
}

@media (max-width: 480px) {
  .promotion-item {
    padding: 15px;
  }

  .promotion-form-modal {
    width: 95%;
    margin: 10px;
  }

  .promotion-form {
    padding: 15px;
  }

  .stats-grid {
    grid-template-columns: 1fr;
  }
}

/* New Checkout Styles */
.checkout-header {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  padding: 24px 32px;
  border-bottom: 1px solid #e9ecef;
  display: flex;
  align-items: center;
  gap: 20px;
}

.checkout-back-btn {
  background: none;
  border: none;
  color: #667eea;
  font-size: 1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: 8px;
  transition: all 0.3s ease;
}

.checkout-back-btn:hover {
  background: rgba(102, 126, 234, 0.1);
}

.checkout-header h1 {
  margin: 0;
  font-size: 1.8rem;
  font-weight: 700;
  color: #2d3748;
}

.checkout-steps {
  display: flex;
  justify-content: center;
  padding: 24px 32px;
  background: #fff;
  border-bottom: 1px solid #e9ecef;
}

.step {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 20px;
  position: relative;
}

.step:not(:last-child)::after {
  content: "";
  position: absolute;
  right: -10px;
  top: 50%;
  transform: translateY(-50%);
  width: 20px;
  height: 2px;
  background: #e9ecef;
}

.step.active:not(:last-child)::after {
  background: #667eea;
}

.step-number {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #e9ecef;
  color: #6c757d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.3s ease;
}

.step.active .step-number {
  background: #667eea;
  color: white;
}

.step-label {
  font-size: 0.9rem;
  color: #6c757d;
  font-weight: 500;
  transition: all 0.3s ease;
}

.step.active .step-label {
  color: #667eea;
  font-weight: 600;
}

.checkout-content {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 0;
  min-height: 600px;
}

.checkout-form {
  padding: 32px;
  border-right: 1px solid #e9ecef;
}

.checkout-section h2 {
  margin: 0 0 24px 0;
  font-size: 1.4rem;
  font-weight: 600;
  color: #2d3748;
  display: flex;
  align-items: center;
  gap: 12px;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 32px;
}

.address-item {
  border: 2px solid #e9ecef;
  border-radius: 12px;
  padding: 20px;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
}

.address-item:hover {
  border-color: #667eea;
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
}

.address-item.selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

.address-info {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.address-name {
  font-weight: 600;
  color: #2d3748;
  font-size: 1.1rem;
}

.address-phone {
  color: #6c757d;
  font-size: 0.9rem;
}

.address-detail {
  color: #495057;
  font-size: 0.95rem;
}

.address-location {
  color: #6c757d;
  font-size: 0.9rem;
}

.address-check {
  position: absolute;
  top: 20px;
  right: 20px;
  color: #667eea;
  font-size: 1.2rem;
}

.payment-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 32px;
}

@media (max-width: 768px) {
  .payment-list {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .payment-item {
    padding: 16px;
    min-height: 100px;
  }

  .payment-icon {
    width: 40px;
    height: 40px;
    font-size: 1.2rem;
  }

  .payment-name {
    font-size: 1rem;
  }

  .payment-description {
    font-size: 0.85rem;
  }
}

@media (max-width: 768px) {
  .payment-list {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .payment-item {
    padding: 16px;
    min-height: 100px;
  }

  .payment-icon {
    width: 40px;
    height: 40px;
    font-size: 1.2rem;
  }

  .payment-name {
    font-size: 1rem;
  }

  .payment-description {
    font-size: 0.85rem;
  }
}

.payment-item {
  border: 2px solid #e9ecef;
  border-radius: 12px;
  padding: 20px;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
  min-height: 120px;
}

.payment-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50px;
  height: 50px;
  border-radius: 12px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  font-size: 1.5rem;
  flex-shrink: 0;
  margin-bottom: 8px;
}

.payment-item:hover {
  border-color: #667eea;
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
}

.payment-item.selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

.payment-info {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.payment-name {
  font-weight: 600;
  color: #2d3748;
  font-size: 1.1rem;
  margin-bottom: 4px;
}

.payment-description {
  color: #6c757d;
  font-size: 0.9rem;
  line-height: 1.4;
}

.payment-check {
  position: absolute;
  top: 12px;
  right: 12px;
  color: #667eea;
  font-size: 1.1rem;
  background: white;
  border-radius: 50%;
  padding: 4px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.checkout-note {
  margin-bottom: 32px;
}

.checkout-note h3 {
  margin: 0 0 12px 0;
  font-size: 1.1rem;
  font-weight: 600;
  color: #2d3748;
}

.checkout-note textarea {
  width: 100%;
  padding: 16px;
  border: 2px solid #e9ecef;
  border-radius: 12px;
  font-size: 0.95rem;
  resize: vertical;
  transition: all 0.3s ease;
}

.checkout-note textarea:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.checkout-actions {
  display: flex;
  gap: 16px;
  justify-content: flex-end;
}

.checkout-next-btn,
.checkout-back-step-btn,
.checkout-process-btn {
  padding: 12px 24px;
  border: none;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.checkout-next-btn,
.checkout-process-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

.checkout-next-btn:hover,
.checkout-process-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
}

.checkout-next-btn:disabled,
.checkout-process-btn:disabled {
  background: #e9ecef;
  color: #6c757d;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.checkout-back-step-btn {
  background: #f8f9fa;
  color: #6c757d;
  border: 2px solid #e9ecef;
}

.checkout-back-step-btn:hover {
  background: #e9ecef;
  color: #495057;
}

.checkout-summary {
  padding: 32px;
  background: #f8f9fa;
}

.checkout-summary h3 {
  margin: 0 0 24px 0;
  font-size: 1.3rem;
  font-weight: 600;
  color: #2d3748;
}

.order-items {
  margin-bottom: 24px;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16px 0;
  border-bottom: 1px solid #e9ecef;
}

.order-item:last-child {
  border-bottom: none;
}

.order-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.order-item-name {
  font-weight: 600;
  color: #2d3748;
  font-size: 0.95rem;
}

.order-item-variant {
  color: #6c757d;
  font-size: 0.85rem;
}

.order-item-price {
  font-weight: 600;
  color: #2d3748;
  font-size: 0.95rem;
}

.order-summary {
  border-top: 2px solid #e9ecef;
  padding-top: 24px;
  margin-bottom: 24px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  font-size: 0.95rem;
}

.summary-row.discount {
  color: #28a745;
  font-weight: 600;
}

.summary-row.total {
  font-weight: 700;
  font-size: 1.1rem;
  color: #2d3748;
  border-top: 1px solid #e9ecef;
  padding-top: 16px;
  margin-top: 8px;
}

.voucher-applied {
  background: rgba(40, 167, 69, 0.1);
  border: 1px solid #28a745;
  border-radius: 8px;
  padding: 16px;
}

.voucher-applied h4 {
  margin: 0 0 8px 0;
  font-size: 0.9rem;
  color: #28a745;
  font-weight: 600;
}

.voucher-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voucher-code {
  font-weight: 600;
  color: #28a745;
  font-size: 0.9rem;
}

.voucher-discount {
  font-weight: 700;
  color: #28a745;
  font-size: 1rem;
}

.checkout-success {
  text-align: center;
  padding: 60px 32px;
}

.success-icon {
  font-size: 4rem;
  margin-bottom: 24px;
}

.checkout-success h2 {
  margin: 0 0 16px 0;
  font-size: 1.8rem;
  font-weight: 700;
  color: #28a745;
}

.checkout-success p {
  margin: 0 0 32px 0;
  color: #6c757d;
  font-size: 1rem;
  line-height: 1.6;
}

.success-actions {
  display: flex;
  justify-content: center;
}

.checkout-continue-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.checkout-continue-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
}

.checkout-loading {
  text-align: center;
  padding: 80px 32px;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* Checkout Responsive */
@media (max-width: 1024px) {
  .checkout-content {
    grid-template-columns: 1fr;
  }

  .checkout-summary {
    border-top: 1px solid #e9ecef;
    border-left: none;
  }
}

@media (max-width: 768px) {
  .checkout-page {
    min-height: calc(100vh - 60px);
    padding: 10px 0;
  }

  .checkout-container {
    margin: 0 10px;
    border-radius: 16px;
  }

  .checkout-header {
    padding: 20px 24px;
  }

  .checkout-header h1 {
    font-size: 1.5rem;
  }

  .checkout-steps {
    padding: 20px 24px;
  }

  .step {
    padding: 0 12px;
  }

  .step-label {
    display: none;
  }

  .checkout-form,
  .checkout-summary {
    padding: 24px;
  }

  .checkout-actions {
    flex-direction: column;
  }

  .checkout-next-btn,
  .checkout-back-step-btn,
  .checkout-process-btn {
    width: 100%;
  }
}

@media (max-width: 480px) {
  .checkout-page {
    min-height: calc(100vh - 50px);
    padding: 5px 0;
  }

  .checkout-container {
    margin: 0 5px;
    border-radius: 12px;
  }

  .checkout-header {
    padding: 16px 20px;
  }

  .checkout-header h1 {
    font-size: 1.3rem;
  }

  .checkout-steps {
    padding: 16px 20px;
  }

  .checkout-form,
  .checkout-summary {
    padding: 20px;
  }

  .address-item,
  .payment-item {
    padding: 16px;
  }

  .checkout-success {
    padding: 40px 20px;
  }

  .success-icon {
    font-size: 3rem;
  }

  .checkout-success h2 {
    font-size: 1.5rem;
  }
}

/* =====================================
   VOUCHER MANAGEMENT STYLES - OPTIMIZED
   ===================================== */

/* Main Container */

/* Header Section */

.header-content h1 {
  color: white;
  margin: 0 0 8px 0;
  font-size: 2.2rem;
  font-weight: 700;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.header-content p {
  color: rgba(255, 255, 255, 0.9);
  margin: 0;
  font-size: 1rem;
  font-weight: 400;
}

/* Search Section */

.search-filters {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 15px;
  align-items: end;
}

.search-filters input,
.search-filters select {
  padding: 12px 16px;
  border: 2px solid #e9ecef;
  border-radius: 10px;
  font-size: 0.95rem;
  transition: all 0.3s ease;
  background: #f8f9fa;
}

.search-filters input:focus,
.search-filters select:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  background: white;
}

/* Content Section */

/* Voucher Grid */
.voucher-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 20px;
  padding: 20px;
}

/* Voucher Item */
.voucher-item {
  background: white;
  border-radius: 15px;
  padding: 20px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border: 1px solid #e9ecef;
  position: relative;
  overflow: hidden;
}

.voucher-item::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.voucher-item:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
}

.voucher-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
  padding-bottom: 15px;
  border-bottom: 1px solid #e9ecef;
}

.voucher-item__code {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  color: #667eea;
  font-size: 0.9rem;
}

.voucher-item__code svg {
  color: #667eea;
}

.voucher-item__status {
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
}

.voucher-item__status.active {
  background: rgba(40, 167, 69, 0.1);
  color: #28a745;
}

.voucher-item__status.inactive {
  background: rgba(220, 53, 69, 0.1);
  color: #dc3545;
}

.voucher-item__status.expired {
  background: rgba(108, 117, 125, 0.1);
  color: #6c757d;
}

/* Voucher Details */
.voucher-item__details {
  margin-bottom: 15px;
}

.voucher-item__detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f8f9fa;
}

.voucher-item__detail:last-child {
  border-bottom: none;
}

.voucher-item__label {
  font-weight: 500;
  color: #6c757d;
  font-size: 0.9rem;
}

.voucher-item__value {
  font-weight: 600;
  color: #2c3e50;
  text-align: right;
}

/* Voucher Actions */
.voucher-item__actions {
  display: flex;
  gap: 8px;
  justify-content: flex-end;
  margin-top: 15px;
  padding-top: 15px;
  border-top: 1px solid #e9ecef;
}

.voucher-item__actions button {
  padding: 8px 12px;
  border: none;
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 4px;
}

.voucher-item__actions .btn-edit {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

.voucher-item__actions .btn-edit:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.voucher-item__actions .btn-delete {
  background: linear-gradient(135deg, #dc3545, #c82333);
  color: white;
}

.voucher-item__actions .btn-delete:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(220, 53, 69, 0.4);
}

/* Form Styles */
.voucher-form {
  padding: 20px;
}

.form-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  margin-bottom: 20px;
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-group label {
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8px;
  font-size: 0.9rem;
}

.form-group input,
.form-group select,
.form-group textarea {
  padding: 12px 16px;
  border: 2px solid #e9ecef;
  border-radius: 10px;
  font-size: 0.95rem;
  transition: all 0.3s ease;
  background: #f8f9fa;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  background: white;
}

.form-group textarea {
  resize: vertical;
  min-height: 100px;
}

.form-actions {
  display: flex;
  gap: 15px;
  justify-content: flex-end;
  margin-top: 30px;
  padding-top: 20px;
  border-top: 1px solid #e9ecef;
}

.form-actions button {
  padding: 12px 24px;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 8px;
}

.form-actions .btn-primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

.form-actions .btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.form-actions .btn-secondary {
  background: #6c757d;
  color: white;
}

.form-actions .btn-secondary:hover {
  background: #5a6268;
  transform: translateY(-2px);
}

/* Modal Styles */
.voucher-form-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1050;
}

.voucher-form-modal .modal-content {
  background: white;
  border-radius: 15px;
  max-width: 800px;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.voucher-form-modal .modal-header {
  padding: 20px;
  border-bottom: 1px solid #e9ecef;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 15px 15px 0 0;
}

.voucher-form-modal .modal-title {
  margin: 0;
  font-size: 1.5rem;
  font-weight: 600;
}

.voucher-form-modal .modal-body {
  padding: 20px;
}

.voucher-form-modal .modal-footer {
  padding: 20px;
  border-top: 1px solid #e9ecef;
  background: #f8f9fa;
  border-radius: 0 0 15px 15px;
}

/* Responsive Design */
@media (max-width: 768px) {
  .voucher-management {
    padding: 15px;
  }

  .voucher-management__header {
    flex-direction: column;
    gap: 15px;
    text-align: center;
  }

  .header-content h1 {
    font-size: 1.8rem;
  }

  .voucher-grid {
    grid-template-columns: 1fr;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .form-actions {
    flex-direction: column;
  }

  .voucher-item__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .voucher-item__actions {
    flex-direction: column;
  }
}

@media (max-width: 480px) {
  .voucher-management {
    padding: 10px;
  }

  .voucher-item {
    padding: 15px;
  }

  .voucher-form-modal {
    width: 95%;
    margin: 10px;
  }

  .voucher-form {
    padding: 15px;
  }
}
